<!doctype html>
<html lang="ja">

<meta charset="utf-8">
<meta name="viewport" content="width=device-width">
<link rel="icon" href="favicon.ico">
<link rel="stylesheet" href="style.css">

<title>{{title}} - 猫野詩梨帳</title>

<header>
  <h1>猫野詩梨帳</h1>
  <p>猫野詩梨 (<a href="https://x.com/CyLomw">@CyLomw</a>) のブログ。</p>
</header>

<main id="entry-main">
  <article>
    <header>
      <h2>{{title}}</h2>
      <time datetime="{{date}}">{{date}}</time>
      <ul>
        {{#each categories}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
    </header>

    {{{content}}}
  </article>
</main>

<footer>
  <a href="index.html">ブログトップへ戻る</a>
</footer>
